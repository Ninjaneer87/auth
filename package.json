{
  "name": "auth",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Authentication monorepo with Express server and React client",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=11"
  },
  "scripts": {
    "preinstall": "node -e \"if(!process.env.npm_config_user_agent?.includes('pnpm')){console.error('Use pnpm to install dependencies.');process.exit(1)}\"",
    "dev": "turbo dev",
    "dev:server": "turbo dev --filter=server",
    "dev:client": "turbo dev --filter=client",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "start": "turbo start --filter=server",
    "db:generate": "dotenv -e packages/server/.env -- pnpm --filter @andrejground/auth db:generate",
    "db:migrate": "dotenv -e packages/server/.env -- pnpm --filter @andrejground/auth db:migrate",
    "db:studio": "dotenv -e packages/server/.env -- pnpm --filter @andrejground/auth db:studio",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "turbo": "^2.8.12",
    "typescript-eslint": "^8.45.0"
  }
}
