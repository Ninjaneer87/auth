{
  "name": "@andrejground/auth",
  "version": "0.0.0",
  "private": true,
  "description": "Authentication library for Express, Drizzle, and Redis",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    }
  },
  "files": ["dist", "drizzle", "drizzle.config.ts"],
  "scripts": {
    "build": "tsc -p tsconfig.src.json && tsc-alias -p tsconfig.src.json",
    "typecheck": "tsc -b --noEmit",
    "dev": "tsc --watch --preserveWatchOutput",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.0",
    "express": "^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
